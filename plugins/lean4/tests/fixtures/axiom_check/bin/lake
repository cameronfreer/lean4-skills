#!/usr/bin/env bash
# Fake `lake env lean <file>` used by test_check_axioms_inline.sh.
# Only supports the `env lean` sub-invocation the script uses.
#
# - Walks the input Lean file line-by-line, tracking the true file line
#   number (so error messages carry ACTUAL file positions, not fake
#   sequence numbers — required because check_axioms_inline.sh classifies
#   errors with line < MARKER_LINE as real-body errors, not appended-region
#   errors).
# - For each `#print axioms <name>` line encountered:
#     * If SEEN_PRINTS_LOG is set, append <name> on its own line to that path.
#     * Emit canned output based on the name prefix so tests can control
#       the verdict. Output format defaults to modern Lean 4:
#         'X' depends on axioms: [ax1, ax2, ...]   — single line, bracketed,
#                                                    decl name in single quotes.
#         Sorry.*    -> "'<name>' depends on axioms: [sorryAx]"    (custom)
#         Unknown.*  -> stderr "<file>:<real_lineno>:0: error: unknown identifier '<name>'"
#         NoAxioms.* -> "'<name>' does not depend on any axioms"   (no deps)
#         Legacy.*   -> "<name> depends on axioms:" + one axiom per line
#                       (older Lean 4 output format — regression coverage)
#         otherwise  -> "'<name>' depends on axioms: [propext, Classical.choice]"
# - Exit 1 if any Unknown.* was emitted, else exit 0. Real Lean exits
#   nonzero on unknown identifier; the shim must too — otherwise
#   check_axioms_inline.sh takes the success-path branch on line 256 and
#   never reaches the not-accessible branch we're testing.
#
# Two output formats are supported (matching modern Lean 4 and the older
# multi-line style respectively). See prefix routing below.
set -euo pipefail

if [[ "${1:-}" != "env" || "${2:-}" != "lean" ]]; then
    echo "shim: unsupported: $*" >&2
    exit 2
fi
lean_file="$3"

had_unknown=0
lineno=0
axiom_re='^#print[[:space:]]+axioms[[:space:]]+(.+)$'
while IFS= read -r cmdline; do
    ((++lineno))
    [[ "$cmdline" =~ $axiom_re ]] || continue
    name="${BASH_REMATCH[1]}"
    if [[ -n "${SEEN_PRINTS_LOG:-}" ]]; then
        printf '%s\n' "$name" >> "$SEEN_PRINTS_LOG"
    fi
    case "$name" in
        Unknown.*)
            # Real file line number positions the error AFTER MARKER_LINE.
            printf "%s:%d:0: error: unknown identifier '%s'\n" \
                "$lean_file" "$lineno" "$name" >&2
            had_unknown=1
            ;;
        Sorry.*)
            printf "'%s' depends on axioms: [sorryAx]\n" "$name"
            ;;
        NoAxioms.*)
            printf "'%s' does not depend on any axioms\n" "$name"
            ;;
        Legacy.*)
            # Preserve legacy multi-line format for a compat regression probe.
            printf '%s depends on axioms:\n' "$name"
            printf 'propext\n'
            printf 'Classical.choice\n'
            ;;
        *)
            printf "'%s' depends on axioms: [propext, Classical.choice]\n" "$name"
            ;;
    esac
done < "$lean_file"

exit "$had_unknown"
